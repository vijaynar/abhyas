# ─────────────────────────────────────────────────────────────
# Upasthiti — Environment Variables Template
# Copy this file as .env.local in apps/web and as .env in apps/mobile
# NEVER commit actual secret values to version control
# ─────────────────────────────────────────────────────────────

# ── Supabase (Local Docker instance defaults shown) ───────────
# Local: http://localhost:54321  |  Cloud: https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-here

# Service role key — ONLY used server-side (API routes), never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-here

# ── Supabase DB Direct Connection (for migrations & admin tools) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Upasthiti

# ── Expo Mobile ───────────────────────────────────────────────
# These are prefixed EXPO_PUBLIC_ so Expo bundles them into the client
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-here
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# ── Deferred — Add when enabling these modules ────────────────
# GEMINI_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# RESEND_API_KEY=
